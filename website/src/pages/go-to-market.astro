---
import CommercialShell from "../components/CommercialShell.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const kpis = [
  {
    label: "Free -> Basic conversion",
    group: "Acquisition",
    description: "Shows whether free tools and paper-safe workflows are creating qualified paid demand.",
  },
  {
    label: "Basic -> Pro conversion",
    group: "Expansion",
    description: "Measures whether active researchers graduate into production-like workflow needs.",
  },
  {
    label: "Pro -> Elite conversion",
    group: "Expansion",
    description: "Tracks demand for tick-level data, deeper diagnostics, reconciliation, and cloud runner capacity.",
  },
  {
    label: "Enterprise pipeline value",
    group: "Enterprise",
    description: "Quantifies private-cloud, broker-partner, and institutional opportunities before contract close.",
  },
  {
    label: "ARR",
    group: "Revenue",
    description: "Annual recurring revenue from SaaS plans, enterprise licensing, data services, and support retainers.",
  },
  {
    label: "NRR",
    group: "Retention",
    description: "Net revenue retention after upgrades, downgrades, churn, add-ons, and enterprise expansion.",
  },
  {
    label: "Churn",
    group: "Retention",
    description: "Signals whether the product is becoming essential infrastructure or remaining a short-lived tool.",
  },
  {
    label: "Active strategy runners",
    group: "Usage",
    description: "Counts research and paper-safe strategy workflows that are active without implying live execution.",
  },
  {
    label: "Data API usage",
    group: "Usage",
    description: "Measures demand for versioned market data, contract master, rollover metadata, and feature datasets.",
  },
  {
    label: "AI diagnosis usage",
    group: "Add-ons",
    description: "Tracks optional analysis demand while keeping outputs research-oriented and non-advisory.",
  },
  {
    label: "Strategy marketplace GMV",
    group: "Ecosystem",
    description: "Future compliance-dependent marketplace volume, tracked separately from trading performance.",
  },
];
---

<BaseLayout title="Go-to-Market | Taifex Quant Trading Platform" description="Go-to-market roadmap for Taiwan futures quant infrastructure." canonicalPath="/go-to-market/" alternatePath="/zh/go-to-market/">
  <CommercialShell
    locale="en"
    active="go-to-market"
    title="Go-to-Market"
    eyebrow="Commercial Growth"
    lead="The commercial path starts with tool-led credibility, expands through ecosystem participation, and matures into enterprise infrastructure."
    englishPath="/go-to-market/"
    chinesePath="/zh/go-to-market/"
  >
    <section class="section">
      <div class="container phase-grid">
        <article class="card"><h2>Phase 1: Tool-led Growth</h2><p>Free rollover-aware backtesting tools, exposure calculator, paper sandbox, and developer-first content.</p></article>
        <article class="card"><h2>Phase 2: Ecosystem Expansion</h2><p>Broker API readiness, strategy marketplace planning, AI diagnostics, and professional trader plans.</p></article>
        <article class="card"><h2>Phase 3: Infrastructure Moat</h2><p>Enterprise licensing, private cloud, RBAC/ABAC, WORM audit direction, SLA, and procurement readiness.</p></article>
      </div>
    </section>

    <section class="section commercial-section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">KPI Dashboard</p>
          <h2>Commercial metrics to track</h2>
        </div>
        <div class="kpi-grid">
          {kpis.map((kpi) => (
            <article class="kpi-card">
              <p class="kpi-group">{kpi.group}</p>
              <h3>{kpi.label}</h3>
              <p>{kpi.description}</p>
            </article>
          ))}
        </div>
        <p class="notice">GTM copy must remain infrastructure-focused and must not promise profitability or risk-free trading.</p>
      </div>
    </section>
  </CommercialShell>
</BaseLayout>
