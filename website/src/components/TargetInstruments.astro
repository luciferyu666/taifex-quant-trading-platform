<section class="section" id="instruments">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Target instruments</p>
      <h2>TX / MTX / TMF exposure normalization</h2>
      <p>
        Taiwan futures sizing needs a shared risk language. TX-equivalent exposure keeps strategy limits,
        portfolio checks, and paper-to-live controls aligned across contract sizes.
      </p>
    </div>
    <div class="instrument-grid">
      <article class="card">
        <h3>TX</h3>
        <p class="metric">NTD 200</p>
        <p>Per index point</p>
      </article>
      <article class="card">
        <h3>MTX</h3>
        <p class="metric">NTD 50</p>
        <p>Per index point</p>
      </article>
      <article class="card">
        <h3>TMF</h3>
        <p class="metric">NTD 10</p>
        <p>Per index point</p>
      </article>
    </div>
    <div class="ratio-strip" aria-label="Contract equivalence">
      <span>1 TX = 4 MTX = 20 TMF</span>
      <span>1 MTX = 5 TMF</span>
    </div>
  </div>
</section>
