---
import type { Locale, PageContent } from "../i18n/content";
import LanguageSwitch from "./LanguageSwitch.astro";
import SiteNav from "./SiteNav.astro";

interface Props {
  locale: Locale;
  page: PageContent;
}

const { locale, page } = Astro.props;
const defaults = ["TRADING_MODE=paper", "ENABLE_LIVE_TRADING=false", "BROKER_PROVIDER=paper"];
const instruments = [
  ["TX", "NTD 200"],
  ["MTX", "NTD 50"],
  ["TMF", "NTD 10"]
];
---

<main>
  <section class="hero section">
    <div class="container topbar">
      <a class="brand-mark" href={page.path}>{page.hero.title}</a>
      <div class="topbar-actions">
        <SiteNav locale={locale} active="home" />
        <LanguageSwitch
          locale={locale}
          label={page.language.label}
          english={page.language.english}
          chinese={page.language.chinese}
          englishPath="/"
          chinesePath="/zh/"
        />
      </div>
    </div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{page.hero.eyebrow}</p>
        <h1>{page.hero.title}</h1>
        <p class="subtitle">{page.hero.subtitle}</p>
        <p class="hero-description">{page.hero.description}</p>
        <div class="hero-value-grid" aria-label={page.hero.valueLabel}>
          {page.hero.values.map((item) => (
            <article class="hero-value-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
        <div class="button-row">
          <a class="button primary" href="#architecture">{page.hero.primaryCta}</a>
          <a class="button secondary" href="#safety">{page.hero.secondaryCta}</a>
        </div>
      </div>
      <div class="hero-panel" aria-label={page.hero.workflowLabel}>
        {page.hero.workflow.map((item, index) => (
          <div class:list={["workflow-row", { active: index === 0, guarded: index >= 4 }]}>
            {item}
          </div>
        ))}
        <p class="panel-note">{page.hero.note}</p>
      </div>
    </div>
  </section>

  <section class="section" id="thesis">
    <div class="container split-section">
      <div>
        <p class="eyebrow">{page.thesis.eyebrow}</p>
        <h2>{page.thesis.title}</h2>
      </div>
      <div class="prose">
        {page.thesis.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section" id="business">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.business.eyebrow}</p>
        <h2>{page.business.title}</h2>
        <p>{page.business.body}</p>
      </div>
      <div class="comparison-grid">
        {page.business.rows.map((row) => (
          <article class="comparison-card">
            <div class="comparison-head">
              <h3>{row.dimension}</h3>
            </div>
            <div class="comparison-item">
              <p class="comparison-label">{page.business.labels.traditional}</p>
              <p>{row.traditional}</p>
            </div>
            <div class="comparison-item">
              <p class="comparison-label">{page.business.labels.platform}</p>
              <p>{row.platform}</p>
            </div>
            <div class="comparison-item highlight">
              <p class="comparison-label">{page.business.labels.impact}</p>
              <p>{row.impact}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="instruments">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.instruments.eyebrow}</p>
        <h2>{page.instruments.title}</h2>
        <p>{page.instruments.body}</p>
      </div>
      <div class="instrument-grid">
        {instruments.map(([symbol, value]) => (
          <article class="card">
            <h3>{symbol}</h3>
            <p class="metric">{value}</p>
            <p>{page.instruments.pointUnit}</p>
          </article>
        ))}
      </div>
      <div class="ratio-strip" aria-label={page.instruments.equivalenceLabel}>
        <span>1 TX = 4 MTX = 20 TMF</span>
        <span>1 MTX = 5 TMF</span>
      </div>
    </div>
  </section>

  <section class="section" id="architecture">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.architecture.eyebrow}</p>
        <h2>{page.architecture.title}</h2>
        <p>{page.architecture.body}</p>
      </div>
      <div class="architecture-map" aria-label={page.architecture.label}>
        <div class="arch-layer">{page.architecture.layers.frontend}</div>
        <div class="arch-connector"></div>
        <div class="arch-layer">{page.architecture.layers.backend}</div>
        <div class="arch-connector"></div>
        <div class="arch-cluster">
          <span>{page.architecture.layers.strategy}</span>
          <span>{page.architecture.layers.data}</span>
          <span>{page.architecture.layers.risk}</span>
          <span>{page.architecture.layers.oms}</span>
          <span>{page.architecture.layers.broker}</span>
        </div>
        <div class="arch-connector"></div>
        <div class="arch-layer muted">{page.architecture.layers.event}</div>
        <div class="arch-connector"></div>
        <div class="arch-cluster storage">
          <span>PostgreSQL</span>
          <span>Redis</span>
          <span>ClickHouse</span>
          <span>{page.architecture.layers.dataLake}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section safety-band" id="safety">
    <div class="container safety-grid">
      <div>
        <p class="eyebrow">{page.safety.eyebrow}</p>
        <h2>{page.safety.title}</h2>
        <p>{page.safety.body}</p>
      </div>
      <div class="defaults-list" aria-label={page.safety.defaultsLabel}>
        {defaults.map((item) => <code>{item}</code>)}
      </div>
    </div>
    <div class="container rule-grid">
      {page.safety.rules.map((rule) => (
        <article class="rule-card">
          <h3>{rule.title}</h3>
          <p>{rule.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section" id="modules">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.modules.eyebrow}</p>
        <h2>{page.modules.title}</h2>
        <p>{page.modules.body}</p>
      </div>
      <div class="module-grid">
        {page.modules.items.map((module) => (
          <article class="card module-card">
            <p class="module-kicker">{module.category}</p>
            <h3>{module.title}</h3>
            <p>{module.body}</p>
            <p class="module-value">{module.value}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section commercial-section" id="commercial">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.commercial.eyebrow}</p>
        <h2>{page.commercial.title}</h2>
        <p>{page.commercial.body}</p>
      </div>
      <p class="commercial-disclaimer">{page.commercial.disclaimer}</p>
      <h3 class="subsection-heading">{page.commercial.pathsTitle}</h3>
      <div class="commercial-path-grid">
        {page.commercial.paths.map((path) => (
          <article class="commercial-path-card">
            <h3>{path.title}</h3>
            <div class="path-detail">
              <p class="path-label">{locale === "zh" ? "服務內容" : "Service"}</p>
              <p>{path.service}</p>
            </div>
            <div class="path-detail">
              <p class="path-label">{locale === "zh" ? "商業邏輯" : "Business logic"}</p>
              <p>{path.logic}</p>
            </div>
            <div class="path-detail">
              <p class="path-label">{locale === "zh" ? "應用場景" : "Use cases"}</p>
              <ul class="compact-list">
                {path.scenarios.map((scenario) => <li>{scenario}</li>)}
              </ul>
            </div>
            <div class="path-detail">
              <p class="path-label">{locale === "zh" ? "客戶價值" : "Value"}</p>
              <p>{path.value}</p>
            </div>
            <p class="path-compliance">{path.compliance}</p>
          </article>
        ))}
      </div>
      <h3 class="subsection-heading">{page.commercial.tiersTitle}</h3>
      <div class="pricing-grid">
        {page.commercial.plans.map((plan) => (
          <article class="plan-card">
            <div class="plan-top">
              <div>
                <h3>{plan.name}</h3>
                <p class="plan-audience">{plan.audience}</p>
              </div>
              <p class="plan-price">{plan.price}</p>
            </div>
            <p class="plan-precision">{plan.precision}</p>
            <ul class="feature-list">
              {plan.features.map((feature) => <li>{feature}</li>)}
            </ul>
          </article>
        ))}
      </div>
      <div class="detail-grid">
        <div>
          <h3 class="subsection-heading">{page.commercial.usageTitle}</h3>
          <div class="phase-grid">
            {page.commercial.usage.map((item) => (
              <article class="card detail-card">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        </div>
        <div>
          <h3 class="subsection-heading">{page.commercial.servicesTitle}</h3>
          <div class="phase-grid">
            {page.commercial.services.map((item) => (
              <article class="card detail-card">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
    <div class="container">
      <p class="notice">{page.commercial.note}</p>
    </div>
  </section>

  <section class="section" id="segments">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.segments.eyebrow}</p>
        <h2>{page.segments.title}</h2>
        <p>{page.segments.body}</p>
      </div>
      <div class="segment-grid">
        {page.segments.items.map((item) => (
          <article class="card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <ul class="feature-list">
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="moat">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.moat.eyebrow}</p>
        <h2>{page.moat.title}</h2>
        <p>{page.moat.body}</p>
      </div>
      <h3 class="subsection-heading">{page.moat.phasesTitle}</h3>
      <div class="phase-grid">
        {page.moat.phases.map((phase) => (
          <article class="card detail-card">
            <h3>{phase.title}</h3>
            <p>{phase.body}</p>
          </article>
        ))}
      </div>
      <h3 class="subsection-heading">{page.moat.advantagesTitle}</h3>
      <div class="advantage-grid">
        {page.moat.advantages.map((item) => (
          <article class="card detail-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="roadmap">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.roadmap.eyebrow}</p>
        <h2>{page.roadmap.title}</h2>
        <p>{page.roadmap.body}</p>
      </div>
      <ol class="roadmap-list">
        {page.roadmap.phases.map((phase) => <li>{phase}</li>)}
      </ol>
    </div>
  </section>

  <section class="section" id="governance">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">{page.governance.eyebrow}</p>
        <h2>{page.governance.title}</h2>
        <p>{page.governance.body}</p>
      </div>
      <div class="governance-grid">
        {page.governance.items.map((item) => (
          <article class="rule-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section compliance-section" id="compliance">
    <div class="container">
      <p class="eyebrow">{page.compliance.eyebrow}</p>
      <h2>{page.compliance.title}</h2>
      <div class="prose wide">
        {page.compliance.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container cta-inner">
      <div>
        <p class="eyebrow">{page.cta.eyebrow}</p>
        <h2>{page.cta.title}</h2>
        <p>{page.cta.body}</p>
      </div>
      <div class="button-row">
        <a class="button primary" href="#">{page.cta.primary}</a>
        <a class="button secondary" href="#safety">{page.cta.secondary}</a>
      </div>
    </div>
  </section>
</main>
