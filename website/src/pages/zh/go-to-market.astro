---
import CommercialShell from "../../components/CommercialShell.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const kpis = [
  {
    label: "Free -> Basic conversion",
    group: "獲客",
    description: "衡量免費工具、換月感知內容與紙上研究流程，是否能轉化為合格付費需求。",
  },
  {
    label: "Basic -> Pro conversion",
    group: "升級",
    description: "觀察研究型使用者是否需要更接近正式營運的資料品質、警示與工作流程。",
  },
  {
    label: "Pro -> Elite conversion",
    group: "升級",
    description: "追蹤 tick-level 資料、多帳戶 reconciliation、AI 診斷與 cloud runner 的需求強度。",
  },
  {
    label: "Enterprise pipeline value",
    group: "企業",
    description: "量化私有雲、券商夥伴與機構採購機會，但不把 pipeline 當成已實現收入。",
  },
  {
    label: "ARR",
    group: "收入",
    description: "年度經常性收入，涵蓋 SaaS 方案、企業授權、資料服務與導入支援。",
  },
  {
    label: "NRR",
    group: "留存",
    description: "淨收入留存率，反映升級、降級、流失、加購與企業擴張後的收入品質。",
  },
  {
    label: "Churn",
    group: "留存",
    description: "判斷產品是成為交易研究基礎設施，或仍只是短期工具的關鍵訊號。",
  },
  {
    label: "Active strategy runners",
    group: "使用",
    description: "追蹤研究與紙上安全流程的活躍程度，不代表 live trading 或券商送單。",
  },
  {
    label: "Data API usage",
    group: "使用",
    description: "衡量版本化行情資料、contract master、rollover metadata 與 feature dataset 的需求。",
  },
  {
    label: "AI diagnosis usage",
    group: "加值",
    description: "追蹤 AI 輔助分析需求；輸出仍定位為研究診斷，不構成投資建議。",
  },
  {
    label: "Strategy marketplace GMV",
    group: "生態系",
    description: "未來合規審查後的策略市集交易量指標，必須與交易績效分開追蹤。",
  },
];
---

<BaseLayout title="市場進入 | 台指期量化交易平台" description="台灣期貨量化基礎設施的市場進入策略。" lang="zh-Hant" canonicalPath="/zh/go-to-market/" alternatePath="/go-to-market/">
  <CommercialShell
    locale="zh"
    active="go-to-market"
    title="市場進入"
    eyebrow="商業成長"
    lead="市場進入路徑先以工具建立信任，再透過生態系擴張，最後走向企業級基礎設施。"
    englishPath="/go-to-market/"
    chinesePath="/zh/go-to-market/"
  >
    <section class="section">
      <div class="container phase-grid">
        <article class="card"><h2>Phase 1：Tool-led Growth</h2><p>免費換月感知回測工具、曝險計算器、紙上交易沙盒與開發者內容。</p></article>
        <article class="card"><h2>Phase 2：Ecosystem Expansion</h2><p>券商 API readiness、策略市集規劃、AI 診斷與專業交易者方案。</p></article>
        <article class="card"><h2>Phase 3：Infrastructure Moat</h2><p>企業授權、私有雲、RBAC/ABAC、WORM 稽核方向、SLA 與採購審查就緒。</p></article>
      </div>
    </section>

    <section class="section commercial-section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">KPI 儀表板</p>
          <h2>應追蹤的商業指標</h2>
        </div>
        <div class="kpi-grid">
          {kpis.map((kpi) => (
            <article class="kpi-card">
              <p class="kpi-group">{kpi.group}</p>
              <h3>{kpi.label}</h3>
              <p>{kpi.description}</p>
            </article>
          ))}
        </div>
        <p class="notice">市場文案必須聚焦基礎設施，不得承諾獲利或宣稱交易無風險。</p>
      </div>
    </section>
  </CommercialShell>
</BaseLayout>
