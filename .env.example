APP_ENV=development
TRADING_MODE=paper
ENABLE_LIVE_TRADING=false
BROKER_PROVIDER=paper
DATABASE_URL=postgresql+psycopg://tqtp:tqtp@postgres:5432/tqtp
REDIS_URL=redis://redis:6379/0
